<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Carnets Estudiantiles</title>
  <style>
    body {
      font-family: Arial;
      background: #f4f4f4;
      text-align: center;
    }
    .card {
      background: white;
      border-radius: 10px;
      padding: 20px;
      margin: 20px auto;
      width: 300px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    .activo {
      color: green;
      font-weight: bold;
    }
    .inactivo {
      color: red;
      font-weight: bold;
    }
  </style>
</head>
<body>

<h1>Carnets Institucionales</h1>

<div id="contenedor"></div>

<script>
const url = "https://opensheet.elk.sh/1_o7wwmT3T9LA4CISZ6fhOiuaq_QfFljKzjHTwDkrKE0/Hoja1";

fetch(url)
  .then(res => res.json())
  .then(data => {
    const contenedor = document.getElementById("contenedor");

    data.forEach(est => {

      const estadoClase = est.ESTADO === "ACTIVO" ? "activo" : "inactivo";

      contenedor.innerHTML += `
        <div class="card">
          <h2>${est.NOMBRE}</h2>
          <p><strong>Código:</strong> ${est.CODIGO}</p>
          <p><strong>Tipo:</strong> ${est.TIPO}</p>
          <p><strong>Curso / Cargo:</strong> ${est.CURSO}</p>
          <p class="${estadoClase}">${est.ESTADO}</p>
        </div>
      `;
    });
  });
</script>

</body>
</html>
